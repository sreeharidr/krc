/**
 * Wrangler config for Cloudflare Workers with Static Assets.
 * This is a pure static site — no Worker code, just HTML/CSS/JS/images.
 * Docs: https://developers.cloudflare.com/workers/static-assets/
 */
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "krc",
  "compatibility_date": "2025-05-22",

  // Serve everything in the repo root as static assets
  "assets": {
    "directory": "./",
    // When a path isn't found, show our custom 404.html
    "not_found_handling": "404-page",
    // Treat /about as /about.html (cleaner URLs in future)
    "html_handling": "auto-trailing-slash"
  },

  // Observability (free, shows logs/errors in Cloudflare dashboard)
  "observability": {
    "enabled": true
  }
}
